from base_plugin import BasePlugin, MethodHook, HookResult, HookStrategy
from hook_utils import find_class
from ui.settings import Input, Header, Selector, Divider, Text
from ui.alert import AlertDialogBuilder
from ui.bulletin import BulletinHelper
from android_utils import run_on_ui_thread
from client_utils import get_last_fragment, send_document
import json
import os
import re
import time
from typing import Any

__id__ = "fix_endpoint_gooey"
__name__ = "Notch Fix"
__description__ = "изменяет конечную точку аватарки в профиле"
__icon__ = "feature_plugins/0"
__version__ = "3.2"
__min_version__ = "12.1.1"
__author__ = "@feature_plugins"

CONF_MODE = "notch_mode"
CONF_RECT_X = "notch_rect_x"
CONF_RECT_Y = "notch_rect_y"
CONF_RECT_W = "notch_rect_w"
CONF_RECT_H = "notch_rect_h"
MODE_HIDE = "0"
MODE_FORCE = "1"

