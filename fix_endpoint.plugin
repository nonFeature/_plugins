def get_language():
    """Определяет язык системы используя Java Locale API"""
    try:
        Locale = find_class("java.util.Locale")
        return "ru" if Locale.getDefault().getLanguage() == "ru" else "en"
    except:
        return "en"

def get_string(key):
    lang = get_language()
    return STRINGS.get(lang, STRINGS["en"]).get(key, STRINGS["en"].get(key, ""))


class NotchImportHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin

    def before_hooked_method(self, param):
        try:
            args = param.args
            if args is None or len(args) == 0:
                return

            chat_cell = args[0]
            if chat_cell is None:
                return

            message_object = chat_cell.getMessageObject()
            if message_object is None:
                return

            document = None
            try:
                document = message_object.getDocument()
            except Exception:
                document = None
            if document is None:
                return

            file_name = ""
            try:
                file_name = str(getattr(document, "file_name", "") or "")
            except Exception:
                file_name = ""
            if not file_name:
                try:
                    FileLoader = find_class("org.telegram.messenger.FileLoader")
                    file_name = str(FileLoader.getAttachFileName(document) or "")
                except Exception:
                    file_name = ""

            if not file_name.lower().endswith(".notch"):
                return

            self.plugin._import_notch_from_message(message_object, document)
            param.setResult(None)
        except Exception as e:
            self.plugin.log(f"Notch import hook failed: {e}")

class Plugin(BasePlugin):
    def __init__(self):
        super().__init__()
        self._import_unhooks = []
        self._import_inflight = set()

    def _parse_dp_value(self, value, default=0.0):
        try:
            text = str(value).strip().replace(",", ".")
            if not text:
                return float(default)
            return float(text)
        except Exception:
            return float(default)

    def _ensure_manual_defaults(self):
        x_str = str(self.get_setting(CONF_RECT_X, "") or "")
        y_str = str(self.get_setting(CONF_RECT_Y, "") or "")
        w_str = str(self.get_setting(CONF_RECT_W, "") or "")
        h_str = str(self.get_setting(CONF_RECT_H, "") or "")

        x_str = x_str or "0"
        y_str = y_str or "0"
        w_str = w_str or "0"
        h_str = h_str or "0"
        self.set_setting(CONF_RECT_X, x_str, reload_settings=False)
        self.set_setting(CONF_RECT_Y, y_str, reload_settings=False)
        self.set_setting(CONF_RECT_W, w_str, reload_settings=False)
        self.set_setting(CONF_RECT_H, h_str, reload_settings=False)
        return x_str, y_str, w_str, h_str

    def _on_mode_changed(self, new_index):
        normalized_mode = MODE_HIDE if int(new_index) == 0 else MODE_FORCE
        current_mode = str(self.get_setting(CONF_MODE, MODE_FORCE))
        if current_mode == normalized_mode:
            return
        if normalized_mode == MODE_FORCE:
            self._ensure_manual_defaults()
        self.set_setting(CONF_MODE, normalized_mode, reload_settings=True)

    def _get_mode_id(self):
        try:
            mode_id = int(self.get_setting(CONF_MODE, MODE_FORCE))
        except Exception:
            mode_id = int(MODE_FORCE)
        return 0 if mode_id == 0 else 1

    def _safe_text(self, value, fallback="unknown"):
        try:
            text = str(value).strip()
            return text if text else fallback
        except Exception:
            return fallback

    def _build_bot_check_url(self):
        return "https://t.me/dot_notch_featureBot"

    def _open_bot_check_link(self):
        def _do():
            try:
                fragment = get_last_fragment()
                activity = fragment.getParentActivity() if fragment else None
                if not activity:
                    raise RuntimeError("No active Activity")
                Intent = find_class("android.content.Intent")
                Uri = find_class("android.net.Uri")
                intent = Intent()
                intent.setAction(Intent.ACTION_VIEW)
                intent.setData(Uri.parse(self._build_bot_check_url()))
                activity.startActivity(intent)
            except Exception as e:
                self.log(f"Open bot link error: {e}")
                try:
                    BulletinHelper.show_info(self._build_bot_check_url())
                except Exception:
                    pass
        run_on_ui_thread(_do)

    def _handle_chat_command(self, params: Any):
        text = getattr(params, "message", None)
        if not isinstance(text, str):
            return None
        normalized = " ".join(text.strip().lower().split())

        export_aliases = {".notch cfg"}
        device_aliases = {".notch device"}

        if normalized in export_aliases:
            dialog_id = 0
            try:
                dialog_id = int(getattr(params, "dialog_id", 0) or 0)
            except Exception:
                dialog_id = 0
            self._export_notch_config(send_to_current_chat=True, dialog_id=dialog_id)
            return HookResult(strategy=HookStrategy.CANCEL)
        if normalized in device_aliases:
            device, _ = self._collect_device_snapshot()
            params.message = self._safe_text(device.get("model", "unknown"), "unknown")
            return HookResult(strategy=HookStrategy.MODIFY, params=params)
        return None

    def on_send_message_hook(self, account: int, params: Any) -> HookResult:
        result = self._handle_chat_command(params)
        if result is not None:
            return result
        return HookResult()

    def _collect_device_snapshot(self):
        Build = find_class("android.os.Build")
        ApplicationLoader = find_class("org.telegram.messenger.ApplicationLoader")
        context = ApplicationLoader.applicationContext
        resources = context.getResources()
        metrics = resources.getDisplayMetrics()
        config = resources.getConfiguration()

        brand = self._safe_text(getattr(Build, "BRAND", "unknown"))
        manufacturer = self._safe_text(getattr(Build, "MANUFACTURER", ""))
        model_raw = self._safe_text(getattr(Build, "MODEL", "unknown"))
        model = self._safe_text((manufacturer + " " + model_raw).strip(), model_raw)
        width_px = int(metrics.widthPixels)
        height_px = int(metrics.heightPixels)
        width_dp = int(getattr(config, "smallestScreenWidthDp", 0))

        return {
            "brand": brand,
            "model": model,
            "resolution": f"{width_px}x{height_px}",
            "width_dp": width_dp,
        }, context

    def _build_export_payload(self, device):
        mode_id = self._get_mode_id()

        payload = {
            "brand": device["brand"],
            "model": device["model"],
            "mode_id": mode_id,
        }

        if mode_id != 0:
            payload.update({
                "resolution": device["resolution"],
                "width_dp": int(device["width_dp"]),
                "offset_x": self._safe_text(self.get_setting(CONF_RECT_X, "0"), "0"),
                "offset_y": self._safe_text(self.get_setting(CONF_RECT_Y, "0"), "0"),
                "width": self._safe_text(self.get_setting(CONF_RECT_W, "0"), "0"),
                "height": self._safe_text(self.get_setting(CONF_RECT_H, "0"), "0"),
            })
        return payload

    def _resolve_message_file_path(self, message_object, document):
        FileLoader = find_class("org.telegram.messenger.FileLoader")
        UserConfig = find_class("org.telegram.messenger.UserConfig")

        try:
            account = int(getattr(message_object, "currentAccount", UserConfig.selectedAccount))
        except Exception:
            account = int(UserConfig.selectedAccount)

        loader = FileLoader.getInstance(account)
        path = None

        try:
            path = loader.getPathToMessage(message_object.messageOwner)
            if path is not None and path.exists():
                return str(path.getAbsolutePath())
        except Exception:
            pass

        try:
            path = loader.getPathToAttach(document, True)
            if path is not None and path.exists():
                return str(path.getAbsolutePath())
        except Exception:
            pass

        try:
            path = loader.getPathToAttach(document, False)
            if path is not None and path.exists():
                return str(path.getAbsolutePath())
        except Exception:
            pass

        return None

    def _compute_compatibility(self, config):
        device, _ = self._collect_device_snapshot()
        issues = []

        model_cfg = str(config.get("model", "") or "").strip()
        resolution_cfg = str(config.get("resolution", "") or "").strip()

        try:
            width_dp_cfg = int(config.get("width_dp"))
        except Exception:
            width_dp_cfg = None

        if model_cfg and model_cfg.lower() != str(device["model"]).lower():
            issues.append(f"model: {model_cfg} != {device['model']}")
        if resolution_cfg and resolution_cfg != str(device["resolution"]):
            issues.append(f"resolution: {resolution_cfg} != {device['resolution']}")
        if width_dp_cfg is not None and width_dp_cfg != int(device["width_dp"]):
            issues.append(f"width_dp: {width_dp_cfg} != {int(device['width_dp'])}")

        return issues

    def _apply_imported_config(self, config):
        try:
            try:
                mode_id = int(config.get("mode_id", 1))
            except Exception:
                mode_id = 1
            mode_id = 0 if mode_id == 0 else 1

            if mode_id != 0:
                x = self._safe_text(config.get("offset_x", "0"), "0")
                y = self._safe_text(config.get("offset_y", "0"), "0")
                w = self._safe_text(config.get("width", "0"), "0")
                h = self._safe_text(config.get("height", "0"), "0")
                self.set_setting(CONF_RECT_X, x, reload_settings=False)
                self.set_setting(CONF_RECT_Y, y, reload_settings=False)
                self.set_setting(CONF_RECT_W, w, reload_settings=False)
                self.set_setting(CONF_RECT_H, h, reload_settings=False)

            self.set_setting(CONF_MODE, str(mode_id), reload_settings=True)
            run_on_ui_thread(lambda: BulletinHelper.show_info(get_string("import_success")))
        except Exception as e:
            error_text = str(e)
            run_on_ui_thread(lambda: BulletinHelper.show_info(f"{get_string('import_fail')}: {error_text}"))

    def _show_import_dialog(self, config, compat_issues):
        def _do_show():
            try:
                fragment = get_last_fragment()
                if fragment is None:
                    return
                activity = fragment.getParentActivity()
                host = activity if activity is not None else fragment.getContext()

                lines = []
                try:
                    mode_id = int(config.get("mode_id", 1))
                except Exception:
                    mode_id = 1
                mode_text = get_string("mode_hide") if mode_id == 0 else get_string("mode_force")
                lines.append(f"mode: {mode_text} ({mode_id})")

                if mode_id != 0:
                    lines.append(f"offset_x: {config.get('offset_x', '0')}")
                    lines.append(f"offset_y: {config.get('offset_y', '0')}")
                    lines.append(f"width: {config.get('width', '0')}")
                    lines.append(f"height: {config.get('height', '0')}")

                if compat_issues:
                    lines.append("")
                    lines.append(get_string("compat_warn"))
                    lines.extend(compat_issues)
                else:
                    lines.append("")
                    lines.append(get_string("compat_ok"))

                dlg = AlertDialogBuilder(host)
                dlg.set_title(get_string("import_title"))
                dlg.set_message("\n".join(lines))
                dlg.set_positive_button(get_string("import_apply"), lambda bld, which: self._apply_imported_config(config))
                dlg.set_negative_button(get_string("import_cancel"), lambda bld, which: bld.dismiss())
                dlg.show()
            except Exception as e:
                self.log(f"Import dialog error: {e}")

        run_on_ui_thread(_do_show)

    def _import_notch_from_message(self, message_object, document):
        key = None
        try:
            key = str(getattr(document, "id", None))
        except Exception:
            key = None
        if not key:
            key = str(id(document))
        if key in self._import_inflight:
            return
        self._import_inflight.add(key)

        def _job():
            try:
                path = self._resolve_message_file_path(message_object, document)
                if not path:
                    raise RuntimeError("notch file path not found")

                with open(path, "r", encoding="utf-8") as f:
                    config = json.loads(f.read())

                if not isinstance(config, dict):
                    raise RuntimeError(get_string("import_invalid"))
                if "mode_id" not in config or "model" not in config:
                    raise RuntimeError(get_string("import_invalid"))

                compat = self._compute_compatibility(config)
                self._show_import_dialog(config, compat)
            except Exception as e:
                self.log(f"Import Error: {e}")
                error_text = str(e)
                run_on_ui_thread(lambda: BulletinHelper.show_info(f"{get_string('import_fail')}: {error_text}"))
            finally:
                self._import_inflight.discard(key)

        import threading
        threading.Thread(target=_job, daemon=True).start()

    def _get_current_dialog_id(self):
        fragment = get_last_fragment()
        if fragment is None:
            return 0
        try:
            field = fragment.getClass().getDeclaredField("dialog_id")
            field.setAccessible(True)
            return int(field.getLong(fragment))
        except Exception:
            pass
        try:
            return int(getattr(fragment, "dialog_id", 0) or 0)
        except Exception:
            return 0

    def _send_notch_to_current_chat(self, target_path, dialog_id=0):
        did = int(dialog_id) if int(dialog_id) != 0 else int(self._get_current_dialog_id())
        if did == 0:
            return False
        try:
            send_document(did, str(target_path), caption="")
            return True
        except Exception as e:
            self.log(f"Direct send error: {e}")
            return False

    def _export_notch_config(self, send_to_current_chat=False, dialog_id=0):
        def _share_file(target_path, context):
            def _do_share():
                try:
                    Intent = find_class("android.content.Intent")
                    File = find_class("java.io.File")
                    Uri = find_class("android.net.Uri")
                    LaunchActivity = find_class("org.telegram.ui.LaunchActivity")
                    file_obj = File(str(target_path))
                    file_uri = Uri.fromFile(file_obj)

                    intent = Intent(context, LaunchActivity)
                    intent.setAction(Intent.ACTION_SEND)
                    intent.setType("application/octet-stream")
                    intent.putExtra(Intent.EXTRA_STREAM, file_uri)
                    intent.addFlags(Intent.FLAG_GRANT_READ_URI_PERMISSION)
                    intent.addFlags(Intent.FLAG_ACTIVITY_NEW_TASK)
                    context.startActivity(intent)
                except Exception as e:
                    self.log(f"Share Error: {e}")
                    error_text = str(e)
                    run_on_ui_thread(lambda: BulletinHelper.show_info(f"{get_string('share_fail')}: {error_text}"))

            run_on_ui_thread(_do_share)

        def _do_export():
            try:
                device, context = self._collect_device_snapshot()
                payload = self._build_export_payload(device)

                from file_utils import get_cache_dir
                directory_path = str(get_cache_dir())
                if not os.path.isdir(directory_path):
                    os.makedirs(directory_path, exist_ok=True)

                model = payload.get("model", "device")
                model = re.sub(r"[^A-Za-z0-9._-]+", "_", str(model)) or "device"
                stamp = str(int(time.time()))
                filename = f"notch_{model}_{stamp}.notch"
                target_path = os.path.join(directory_path, filename)

                with open(target_path, "w", encoding="utf-8") as f:
                    f.write(json.dumps(payload, ensure_ascii=False, indent=2))

                if send_to_current_chat:
                    sent = self._send_notch_to_current_chat(target_path, dialog_id=dialog_id)
                    if sent:
                        return
                    run_on_ui_thread(lambda: BulletinHelper.show_info(get_string("share_fail")))
                    return
                _share_file(target_path, context)
            except Exception as e:
                self.log(f"Export Error: {e}")
                error_text = str(e)
                run_on_ui_thread(lambda: BulletinHelper.show_info(f"{get_string('export_fail')}: {error_text}"))

        import threading
        threading.Thread(target=_do_export, daemon=True).start()

    def on_plugin_load(self):
        try:
            target = find_class("org.telegram.messenger.NotchInfoUtils")
            m = target.getClass().getDeclaredMethod("getInfo", find_class("android.content.Context"))
            m.setAccessible(True)
            self.hook_method(m, NotchHook(self))
        except Exception as e:
            self.log(f"Hook Error: {e}")
        try:
            self.add_on_send_message_hook()
        except Exception as e:
            self.log(f"Send hook register error: {e}")
        self._install_import_hook()

    def on_plugin_unload(self):
        if self._import_unhooks:
            for unhook in self._import_unhooks:
                try:
                    self.unhook_method(unhook)
                except Exception:
                    pass
        self._import_unhooks = []
        self._import_inflight.clear()

    def _install_import_hook(self):
        try:
            target = find_class("org.telegram.ui.ChatActivity$ChatMessageCellDelegate")
            if not target:
                return
            hook = NotchImportHook(self)
            self._import_unhooks = self.hook_all_methods(target, "didPressImage", hook, 50)
        except Exception as e:
            self.log(f"Import hook install failed: {e}")

    def create_settings(self):
        current_mode = self._get_mode_id()
        current_x, current_y, current_w, current_h = self._ensure_manual_defaults()

        items = [get_string("mode_hide"), get_string("mode_force")]
        settings = [
            Selector(
                key=CONF_MODE,
                text=get_string("label_mode"),
                default=current_mode,
                items=items,
                on_change=self._on_mode_changed
            )
        ]

        if current_mode == 1:
            settings.extend([
                Input(CONF_RECT_X, get_string("label_x"), default=current_x),
                Input(CONF_RECT_Y, get_string("label_y"), default=current_y),
                Input(CONF_RECT_W, get_string("label_w"), default=current_w),
                Input(CONF_RECT_H, get_string("label_h"), default=current_h),
                Header(get_string("force_hint"))
            ])

        settings.append(Divider())

        settings.append(
            Text(
                text=get_string("export_btn"),
                accent=True,
                icon="action_share",
                on_click=lambda v: self._export_notch_config()
            )
        )
        settings.append(
            Text(
                text=get_string("bot_check_btn"),
                on_click=lambda v: self._open_bot_check_link()
            )
        )

        return settings

class NotchHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin
        # Кэшируем класс при инициализации, чтобы не искать его каждый раз
        self._au_class = None

    def _get_au_class(self):
        """Кэшируем AndroidUtilities класс"""
        if self._au_class is None:
            self._au_class = find_class("org.telegram.messenger.AndroidUtilities")
        return self._au_class

    def after_hooked_method(self, param):
        try:
            original = param.getResult()
            mode = self.plugin._get_mode_id()
            
            # Режим 0 - "выреза нету" - возвращаем null
            if mode == 0:
                if original is not None:
                    param.setResult(None)
                return
            
            # Любой ненулевой режим считаем ручным
            if mode != 0:
                self.plugin._ensure_manual_defaults()
                x_str = self.plugin.get_setting(CONF_RECT_X, "0")
                y_str = self.plugin.get_setting(CONF_RECT_Y, "0")
                w_str = self.plugin.get_setting(CONF_RECT_W, "0")
                h_str = self.plugin.get_setting(CONF_RECT_H, "0")

                AU = self._get_au_class()

                x_dp = self.plugin._parse_dp_value(x_str, 0.0)
                y_dp = self.plugin._parse_dp_value(y_str, 0.0)
                w_dp = self.plugin._parse_dp_value(w_str, 0.0)
                h_dp = self.plugin._parse_dp_value(h_str, 0.0)

                if original is None and w_dp <= 0 and h_dp <= 0:
                    return

                if original is None:
                    NotchInfo = find_class("org.telegram.messenger.NotchInfoUtils$NotchInfo")
                    RectF = find_class("android.graphics.RectF")
                    original = NotchInfo.newInstance()
                    original.bounds = RectF.newInstance()
                    param.setResult(original)

                base_left_px = float(original.bounds.left) if original is not None else 0.0
                base_top_px = float(original.bounds.top) if original is not None else 0.0
                base_width_px = float(original.bounds.width()) if original is not None else 0.0
                base_height_px = float(original.bounds.height()) if original is not None else 0.0

                if x_dp == 0.0 and original is not None:
                    l_px = base_left_px
                else:
                    l_px = float(AU.dp(float(x_dp)))

                if y_dp == 0.0 and original is not None:
                    t_px = base_top_px
                else:
                    t_px = float(AU.dp(float(y_dp)))

                if original is not None and w_dp <= 0:
                    width_px = base_width_px
                else:
                    width_px = base_width_px + float(AU.dp(float(w_dp))) if original is not None else float(AU.dp(float(w_dp)))

                if original is not None and h_dp <= 0:
                    height_px = base_height_px
                else:
                    height_px = base_height_px + float(AU.dp(float(h_dp))) if original is not None else float(AU.dp(float(h_dp)))

                r_px = l_px + width_px
                b_px = t_px + height_px

                # Применяем границы
                b = original.bounds
                b.left = l_px
                b.top = t_px
                b.right = r_px
                b.bottom = b_px
                
                # Настройки типа выреза
                original.gravity = 17 # CENTER
                original.isLikelyCircle = True

        except Exception:
            pass

